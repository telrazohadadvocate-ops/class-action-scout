# Class Action Scout — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to source control.

# ── Dashboard Auth ────────────────────────────────────
DASHBOARD_PASSWORD=choose-a-strong-password
FLASK_SECRET_KEY=generate-with-python-secrets-token-hex-32

# ── Claude / Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── PACER (PacerMonitor login) ─────────────────────────
PACER_USERNAME=ohad@levin-telraz.co.il
PACER_PASSWORD=

# ── Outlook / Microsoft Graph ──────────────────────────
# Required for the Law360 newsletter scraper.
#
# Setup steps:
#   1. Go to portal.azure.com → App registrations → New registration
#   2. Name: "Class Action Scout"
#      Supported account types: "Accounts in this organizational directory only"
#      (or "Single tenant")
#   3. Redirect URI: Public client/native → http://localhost
#   4. API permissions → Microsoft Graph → Delegated → Mail.Read → Grant admin consent
#   5. Authentication → Advanced settings → Allow public client flows → YES
#   6. Copy Application (client) ID → OUTLOOK_CLIENT_ID
#      Copy Directory (tenant) ID  → OUTLOOK_TENANT_ID
#
#   Then run:  python scripts/setup_outlook.py
#
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=
OUTLOOK_USER_EMAIL=Ohad@levin-telraz.co.il

# ── Gmail (legacy — not used if Outlook is configured) ─
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ── SMTP (weekly report emails) ───────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_RECIPIENTS=ohad@levin-telraz.co.il
